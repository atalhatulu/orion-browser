{
  "name": "orion-browser",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "dev": "concurrently \"electron .\" \"electron-wait-for-react-scripts\"",
    "watch": "electron-reload .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "lint": "eslint . --ext .js",
    "format": "prettier --write ."
  },
  "build": {
    "appId": "com.orion.browser",
    "productName": "OrionBrowser",
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ]
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "electron-reload": "^1.5.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2"
  }
}
